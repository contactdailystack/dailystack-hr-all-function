# DailyStack HR API - Local Development Variables
# Copy this file to .dev.vars and fill in your values
# DO NOT commit .dev.vars (it's already in .gitignore)

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# LINE Messaging API (required)
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_CHANNEL_SECRET=your-channel-secret
LINE_LIFF_ID=your-liff-id

# LINE Webhook Verify Token (set this to a random string)
LINE_WEBHOOK_VERIFY_TOKEN=your-random-verify-token

# Environment
NODE_ENV=development
